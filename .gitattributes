# Normalize line endings to avoid Linux<->Windows churn.
# Unity YAML, scripts, configs = text (LF in repo).
* text=auto eol=lf

# Force these to be treated as text and merged with Unity's smart merge where possible
*.cs       text diff=csharp
*.shader   text
*.cginc    text
*.hlsl     text
*.uxml     text
*.uss      text
*.json     text
*.md       text
*.txt      text
*.yml      text
*.yaml     text
# Unity asset files are YAML text — keep them diffable
*.meta            text
*.unity           text
*.prefab          text
*.asset           text
*.mat             text
*.anim            text
*.controller      text
*.physicsMaterial2D text
*.spriteatlas     text
# ----------------------------------------------------------------------------
# Git LFS — binary assets (images, audio, etc.)
# (Requires `git lfs install` on both Linux and Windows.)
*.png      filter=lfs diff=lfs merge=lfs -text
*.jpg      filter=lfs diff=lfs merge=lfs -text
*.jpeg     filter=lfs diff=lfs merge=lfs -text
*.gif      filter=lfs diff=lfs merge=lfs -text
*.psd      filter=lfs diff=lfs merge=lfs -text
*.aseprite filter=lfs diff=lfs merge=lfs -text
*.ase      filter=lfs diff=lfs merge=lfs -text
*.wav      filter=lfs diff=lfs merge=lfs -text
*.mp3      filter=lfs diff=lfs merge=lfs -text
*.ogg      filter=lfs diff=lfs merge=lfs -text
*.ttf      filter=lfs diff=lfs merge=lfs -text
*.otf      filter=lfs diff=lfs merge=lfs -text
